# Deep Owl — environment template (v0.1.0 — big caps CEX-first)
# Skopiuj do .env i uzupelnij. .env JEST gitignored.

# === API keys (Faza 2: universe building) ===
# CoinMarketCap (free tier 333 req/dzien, https://coinmarketcap.com/api/)
COINMARKETCAP_API_KEY=

# CoinGecko Pro — opcjonalne, tylko jesli free tier 30 req/min nie wystarcza
COINGECKO_API_KEY=

# === Telegram bot (Faza 6+) — utworz przez @BotFather ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === CEX REST APIs (Faza 3) ===
# Public endpoints — NIE wymagaja auth dla klines/funding/OI:
#   Binance, Bybit, OKX, Coinbase Exchange
# Brak kluczy potrzebnych w tej fazie

# === Runtime config ===
# Sciezka do DuckDB (default: ./data/deep_owl.duckdb)
DEEPOWL_DB_PATH=./data/deep_owl.duckdb

# Logging level: DEBUG | INFO | WARNING | ERROR
DEEPOWL_LOG_LEVEL=INFO

# Dashboard port (FastAPI)
DEEPOWL_DASHBOARD_PORT=8001

# === Parent integration (Faza 3 opcjonalne — tick precision dla BTC/ETH/HYPE) ===
# Sciezka do parent recorder data dir (read-only reuse)
PARENT_RECORDER_DATA_PATH=D:/Crypto/Claude/data
